# Backend environment configuration
PORT=5000
NODE_ENV=production
ALLOW_ADMIN=false

# Use local DB for local tests. In prod, set Atlas URI.
MONGO_URI=mongodb://127.0.0.1:27017/kitchen-gallery
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/kitchen-gallery?retryWrites=true&w=majority

# Frontend URL for CORS
FRONTEND_URL=https://your-frontend-url.vercel.app

# Upstash Redis for rate-limiting (recommended for production)
UPSTASH_REDIS_REST_URL=https://<your-upstash-url>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-upstash-token>

# JWT Secrets
JWT_ACCESS_SECRET=<secure-random-string>
JWT_REFRESH_SECRET=<secure-random-string>

# Razorpay (optional)
RAZORPAY_KEY_ID=<your-key-id>
RAZORPAY_KEY_SECRET=<your-key-secret>

# Twilio WhatsApp (optional)
TWILIO_ACCOUNT_SID=<your-account-sid>
TWILIO_AUTH_TOKEN=<your-auth-token>
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
